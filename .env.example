# --- Public site ---
# Absolute site origin — used for RSS, sitemap, canonical URLs, and OG images.
# Set this in Vercel (Production) to your deployed origin. Falls back to
# http://localhost:3000 in local dev.
NEXT_PUBLIC_SITE_URL=https://frontgem.vercel.app

# --- Admin (/write) auth ---
# Single password for the admin editor.
BLOG_ADMIN_PASSWORD=change-me
# Secret used to sign the session cookie (HMAC). Use a long random string.
AUTH_SECRET=generate-a-long-random-string

# --- Publishing (GitHub Contents API) ---
# Fine-grained PAT with Contents: read+write on the blog repo.
GITHUB_TOKEN=github_pat_xxx
# Target repo/branch for published MDX. Defaults shown; override if needed.
GITHUB_OWNER=gembitious
GITHUB_REPO=frontgem
GITHUB_BRANCH=main

# --- lapidary 퇴고 엔진 (Anthropic) ---
# API key for the /api/revise rewrite proxy.
ANTHROPIC_API_KEY=sk-ant-xxx
# Optional model override. Defaults to claude-sonnet-5 (글쓰기 품질/비용 균형 최적).
# claude-opus-4-8 (최상급), claude-haiku-4-5 (최저가) 등으로 변경 가능.
ANTHROPIC_MODEL=claude-sonnet-5

# 목 모드: 1로 켜면 AI 호출 없이 규칙 기반 퇴고로 diff/머지/라운드 흐름을 테스트.
# ANTHROPIC_API_KEY 없이도 동작. 실제 발행 환경에선 켜지 말 것.
# LAPIDARY_MOCK=1
